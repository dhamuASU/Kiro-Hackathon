{
  "name": "pm",
  "description": "Project manager — creates GitHub issues, tracks progress, coordinates team",
  "prompt": "file://./prompts/pm.md",
  "tools": ["read", "shell", "@github", "@aws-docs"],
  "allowedTools": ["read", "@github"],
  "resources": [
    "file://.kiro/steering/**/*.md",
    "file://.kiro/plans/**/*.md"
  ],
  "hooks": {
    "agentSpawn": [
      { "command": "git log --oneline -5 2>/dev/null || echo 'No git history'", "timeout_ms": 5000 }
    ]
  },
  "keyboardShortcut": "ctrl+1",
  "welcomeMessage": "PM agent ready. I can create issues, check status, and coordinate the team."
}
