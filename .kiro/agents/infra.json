{
  "name": "infra",
  "description": "Infrastructure & AWS specialist — CDK stacks, cloud architecture, deploys, cost optimization",
  "prompt": "file://./prompts/infra.md",
  "tools": ["read", "write", "shell", "aws", "@aws-docs", "@cdk"],
  "allowedTools": ["read", "aws", "@aws-docs", "@cdk"],
  "toolsSettings": {
    "write": { "allowedPaths": ["infra/**", "scripts/**", "cdk.json", "*.yaml", "*.yml", "*.json"] },
    "aws": {
      "allowedServices": ["cloudformation", "s3", "lambda", "dynamodb", "apigateway", "cloudfront", "iam", "sts", "logs", "ec2", "budgets"]
    }
  },
  "resources": [
    "file://README.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/cdk-patterns/SKILL.md",
    "file://infra/**/*.ts"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "aws sts get-caller-identity 2>/dev/null || echo 'Not authenticated — run: aws configure sso'",
        "timeout_ms": 10000,
        "cache_ttl_seconds": 300
      }
    ]
  },
  "keyboardShortcut": "ctrl+4",
  "welcomeMessage": "Infra & AWS agent ready. CDK stacks, cloud architecture, deploys, cost optimization."
}
