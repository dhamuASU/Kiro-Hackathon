{
  "name": "debug",
  "description": "Debugger & incident response — errors, CloudWatch, stack traces, all commands auto-logged",
  "prompt": "file://./prompts/debug.md",
  "tools": ["read", "shell", "aws", "@aws-docs"],
  "allowedTools": ["read", "@aws-docs"],
  "toolsSettings": {
    "aws": {
      "allowedServices": ["logs", "cloudwatch", "lambda", "apigateway", "dynamodb", "cloudformation"],
      "autoAllowReadonly": true
    }
  },
  "resources": [
    "file://.kiro/steering/**/*.md",
    "file://backend/src/**/*.ts",
    "file://frontend/src/**/*.tsx",
    "file://infra/**/*.ts"
  ],
  "hooks": {
    "agentSpawn": [
      { "command": "echo \"🔍 Debug session started at $(date)\" >> /tmp/incident-log.txt", "timeout_ms": 3000 }
    ],
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "{ echo \"$(date) - Command:\"; cat; echo; } >> /tmp/incident-log.txt"
      }
    ]
  },
  "keyboardShortcut": "ctrl+6",
  "welcomeMessage": "Debug agent ready. All commands logged to /tmp/incident-log.txt. Paste the error or describe what's broken."
}
