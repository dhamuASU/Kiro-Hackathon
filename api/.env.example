# ─────────────────────────────────────────────────────────────────────────────
# CleanLabel API — environment template
#
# Copy this to `.env` and fill in the real values. `.env` is gitignored at the
# repo root so your secrets don't get committed. The backend reads `.env`
# from the current working directory (usually `api/` when you run uvicorn).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# The "service_role" key — bypasses RLS. NEVER expose to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# The project's JWT secret, used to verify auth.users() tokens server-side.
# Found at: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Vertex AI / Gemini (required) ────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
VERTEXAI_API_KEY=your-google-vertexai-api-key
VERTEXAI_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic ──────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# CLAUDE_MODEL=claude-3-5-haiku-20241022

# ── Open Beauty Facts (required — has a sensible default) ────────────────────
OBF_BASE_URL=https://world.openbeautyfacts.org/api/v2

# ── App config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# JSON array of allowed CORS origins. Add your Vercel preview URL here in prod.
CORS_ORIGINS=["http://localhost:3000"]
# Reserved for demo-only auth shortcuts. Leave false in normal operation.
DEMO_MODE=false
